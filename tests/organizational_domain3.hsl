-----END PRIVATE KEY-----'');

echo "--- test organizational domain (from, dkim)";

$mail = MIME();
$mail->addHeader("From", "erik@another.example.com");
$mail->setBody("Hello");
$mail->signDKIM("spaceship", "mydomain.example.com", $privkey);

$res = dmarc_implementation(MailMessage::String($mail->toString()), "127.0.0.1", "", "example.com", function($ip, $helo, $sender) {
    if ($ip == "127.0.0.1" and
        $helo == "" and
        $sender == "example.com")
        return ["result" => "pass", "reason" => "localhost"];
    throw "spf_query($ip, $helo, $sender)";
}, function($host, $options = []) {
    if ($host == "_dmarc.another.example.com" and $options == ["type" => "txt"])
        return ["error" => "NXDOMAIN"];
    if ($host == "_dmarc.example.com" and $options == ["type" => "txt"])
        return ["result" => ["v=DMARC1; p=reject"]];
    throw "dns_query($host)";
}, function($host) {
    global $dns;
    if ($host == "spaceship._domainkey.mydomain.example.com")
        return ["result" => $dns];
    throw "dkim_dns_query($host)";
});

if ($res["spf_align"] == "pass" and
    $res["dkim_align"] == "pass" and
    $res["result"] == "pass" and
    $res["pdomain"] == "example.com" and
    $res["policy"] == "reject")
    echo " OK";
else
    throw $res;