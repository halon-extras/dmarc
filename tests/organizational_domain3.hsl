import { dmarc_implementation } from "file://dmarc.hsl";

$dns = "v=DKIM1; k=rsa; p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBg".
"QCpRIzmELwgc6MIvckFjwL8QT6lMdJKAH1IAU1cOstYRHrQdsRshnpZCMg778P".
"rPnPdmrm5XCd48YTnniuHUvXIkHPO+vUDlv3u+N1gtUOD1oHKCrqiKTcNgB2J/".
"4+FY7GridqjFlg06QqVoX7a3WY8pmvILxagJynZSE729QF0jQIDAQAB";

$privkey = rsa_privatekey(''-----BEGIN PRIVATE KEY-----
MIICdgIBADANBgkqhkiG9w0BAQEFAASCAmAwggJcAgEAAoGBAKlEjOYQvCBzowi9
yQWPAvxBPqUx0koAfUgBTVw6y1hEetB2xGyGelkIyDvvw+s+c92aublcJ3jxhOee
K4dS9ciQc8769QOW/e743WC1Q4PWgcoKuqIpNw2AHYn/j4VjsauJ2qMWWDTpCpWh
ftrdZjyma8gvFqAnKdlITvb1AXSNAgMBAAECgYB8rbqfB/qaaLLREIIObx3C0wgi
xATib2PYcuUZp1D6rk5MWP8r9Q4PoNFknKISGAleVMayivekNToxJSdo4SmaI3p/
tY0ceKlsoJEEXBA/lZVrNKM69PvDmtXaSLuAX4KfrsF5jHd+UaeINgtGzE0Ngqre
wdlTA9FyYFypCiqUHQJBAOEbuOjtNYWFhhUuh0BJammBbskoZ3BwVu3KiNLXIwM6
