import { dnsWalk } from "file://dmarc.hsl";

echo "test dnsWalk with organizational domain with psd=n (author domain)";

$result = dnsWalk("a.b.example.com", function($host, $options = []) {
    if ($host == "_dmarc.a.b.example.com" and $options == ["type" => "txt"])
        return ["result" => ["v=DMARC1; p=reject; psd=n"]];
    throw "dns_query($host)";
});
if ($result != [
        "policy" => ["p" => "reject", "psd" => "n", "v" => "DMARC1"],
        "pdomain" => "a.b.example.com",
        "orgdomain" => "a.b.example.com"])
    throw $result;
else
    echo " OK";